TELEGRAM_BOT_TOKEN=0000000000:replace-me
TELEGRAM_SECRET_TOKEN=replace-with-setWebhook-secret-token
ADMIN_TOKEN=replace-with-long-random-token
ADMIN_TELEGRAM_IDS=123456789
EMAIL_ENCRYPTION_KEY=replace-with-long-random-secret
EMAIL_HASH_PEPPER=replace-with-long-random-pepper

# Server4-native runtime
BUDDY_DB_PATH=/var/lib/codex-buddy/codex-buddy.sqlite
BUDDY_HOST=127.0.0.1
BUDDY_PORT=18788
BUDDY_PUBLIC_BASE_URL=https://bot.example.com
TELEGRAM_WEBHOOK_CERT_PATH=/etc/codex-buddy/webhook-cert.pem
